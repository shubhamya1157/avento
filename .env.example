# ===========================================================================
# Avento — environment template
# ===========================================================================
# Copy this file to ".env.local" and fill in the values:
#     cp .env.example .env.local
# Lines marked REQUIRED must be set for the app to run. Everything marked
# OPTIONAL has a graceful fallback, so the app still works without it.
# ===========================================================================

# Database — REQUIRED. Your MongoDB connection string.
MONGODB_URL=

# NextAuth — REQUIRED. A random secret used to sign login sessions.
# Generate one with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth (OPTIONAL) — only needed for the "Continue with Google" button.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email (REQUIRED for signup OTP) — a Gmail address + App Password.
# App passwords: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=

# Admins — comma-separated emails that get the "admin" role automatically on
# login (no manual DB editing). Example: you@example.com,boss@example.com
ADMIN_EMAILS=

# Chatbot (OPTIONAL) — Claude API key. Without it the help chatbot still answers
# from built-in rules; with it, free-form questions are answered by Claude.
ANTHROPIC_API_KEY=

# Razorpay payments (OPTIONAL) — TEST keys from https://dashboard.razorpay.com
# Without these, booking works in a no-charge "demo" mode.
#   RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET  : used on the SERVER (kept secret)
#   NEXT_PUBLIC_RAZORPAY_KEY_ID            : the SAME key id, exposed to the
#                                            browser so checkout can open.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Cloudinary image hosting (OPTIONAL) — free account at https://cloudinary.com
# Without these, uploaded photos save to local disk (public/uploads).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Realtime (OPTIONAL) — the URL the browser uses to reach the Socket.io server
# (used by live chat + video call). Leave blank to use the same origin the app
# is served from, which is correct for local dev (node server.js on :3000).
NEXT_PUBLIC_SOCKET_URL=
